# ── Frontend ─────────────────────────────────────────────────────────────────
# URL of the NestJS backend API.
# Development: http://localhost:3001/api
# Production:  https://your-backend.onrender.com/api
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ── Seed scripts only ────────────────────────────────────────────────────────
# scripts/seed-sample-data.js and scripts/clear-database.js read MONGODB_URI
# directly from this file. Not used by the Next.js frontend itself.
MONGODB_URI=mongodb://localhost:27017/studynest
