# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/interview-prep

# JWT signing secret — use a strong random value in production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Port the NestJS server listens on (Render will set this automatically)
PORT=3001

# The URL of your Next.js frontend (used for CORS and password reset links)
FRONTEND_URL=http://localhost:3000

# Node environment
NODE_ENV=development

# Gmail SMTP credentials for password reset emails (optional in development)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
